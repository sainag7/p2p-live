{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "api-server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server/index.cjs"],
      "port": 3001
    },
    {
      "name": "scraper-server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "scraper", "start"],
      "port": 3002
    }
  ]
}
